<Application x:Class="WorldCup2026.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WorldCup2026"
             xmlns:converters="clr-namespace:WorldCup2026.Converters">
    <Application.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />

        <!-- Colors / Brushes -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1a365d" />
        <SolidColorBrush x:Key="AccentBrush" Color="#c8a951" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2d6a4f" />
        <SolidColorBrush x:Key="LiveBrush" Color="#d00000" />
        <SolidColorBrush x:Key="BgLightBrush" Color="#f0f2f5" />
        <SolidColorBrush x:Key="CardBgBrush" Color="#ffffff" />

        <!-- Global Styles -->
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a4f7d" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Application.Resources>
</Application>
